rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsExistingDoc() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function writesOwnDoc() {
      return signedIn()
        && request.resource.data.ownerUid == request.auth.uid;
    }

    function ownsUserProfile(userId) {
      return signedIn() && userId == request.auth.uid;
    }

    function writesOwnUserProfile(userId) {
      return ownsUserProfile(userId)
        && request.resource.data.schema == 'temperaturna-lista-user-profile-v1'
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.department is string;
    }

    match /patients/{patientId} {
      allow create: if writesOwnDoc();
      allow read, delete: if ownsExistingDoc();
      allow update: if ownsExistingDoc() && writesOwnDoc();
    }

    match /parserTestCases/{caseId} {
      allow create: if writesOwnDoc();
      allow read, delete: if ownsExistingDoc();
      allow update: if ownsExistingDoc() && writesOwnDoc();
    }

    match /userProfiles/{userId} {
      allow read: if ownsUserProfile(userId);
      allow create, update: if writesOwnUserProfile(userId);
    }
  }
}
