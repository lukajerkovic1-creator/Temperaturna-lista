rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profilePath() {
      return /databases/$(database)/documents/userProfiles/$(request.auth.uid);
    }

    function hasUserProfile() {
      return signedIn() && exists(profilePath());
    }

    function userProfile() {
      return get(profilePath()).data;
    }

    function allowedClinicalRoles() {
      return ['clinician', 'physician', 'nurse', 'admin'];
    }

    function superAdminEmails() {
      return ['luka.jerkovic1@gmail.com'];
    }

    function isSuperAdmin() {
      return signedIn()
        && request.auth.token.email in superAdminEmails()
        && hasUserProfile()
        && userProfile().email == request.auth.token.email
        && userProfile().roles is list
        && userProfile().roles.hasAny(['admin']);
    }

    function hasClinicalRole() {
      return hasUserProfile()
        && userProfile().roles is list
        && userProfile().roles.hasAny(allowedClinicalRoles());
    }

    function validClinicalProfileData(data, userId) {
      return data.schema == 'temperaturna-lista-user-profile-v1'
        && data.uid == userId
        && data.email == request.auth.token.email
        && data.firstName is string
        && data.lastName is string
        && data.department is string
        && data.organizationId is string
        && data.activeWardId is string
        && data.wardIds is list
        && data.roles is list
        && data.organizationId.size() > 0
        && data.activeWardId.size() > 0
        && data.activeWardId in data.wardIds
        && data.roles.hasAny(allowedClinicalRoles())
        && data.roles.hasOnly(allowedClinicalRoles());
    }

    function validManagedUserProfileData(data, userId) {
      return data.schema == 'temperaturna-lista-user-profile-v1'
        && data.uid == userId
        && data.email is string
        && data.firstName is string
        && data.lastName is string
        && data.department is string
        && data.organizationId is string
        && data.activeWardId is string
        && data.wardIds is list
        && data.roles is list
        && data.organizationId.size() > 0
        && data.activeWardId.size() > 0
        && data.activeWardId in data.wardIds
        && data.roles.hasAny(allowedClinicalRoles())
        && data.roles.hasOnly(allowedClinicalRoles());
    }

    function hasClinicalAccess(organizationId, wardId) {
      return hasUserProfile()
        && hasClinicalRole()
        && organizationId is string
        && wardId is string
        && userProfile().organizationId == organizationId
        && wardId in userProfile().wardIds;
    }

    function partitionKey(organizationId, wardId) {
      return 'clinical-v1|' + organizationId + '|' + wardId;
    }

    function writesClinicalDocument(data) {
      return signedIn()
        && data.ownerUid == request.auth.uid
        && data.accessModel == 'organization-ward-role-v1'
        && data.organizationId is string
        && data.wardId is string
        && data.clinicalPartitionKey == partitionKey(data.organizationId, data.wardId)
        && hasClinicalAccess(data.organizationId, data.wardId);
    }

    function readsClinicalDocument(data) {
      return data.accessModel == 'organization-ward-role-v1'
        && data.organizationId is string
        && data.wardId is string
        && data.clinicalPartitionKey == partitionKey(data.organizationId, data.wardId)
        && hasClinicalAccess(data.organizationId, data.wardId);
    }

    function readsLegacyOwnedPatientForMigration(data) {
      return signedIn()
        && data.schema == 'temperaturna-lista-patient-v1'
        && (
          data.ownerUid == request.auth.uid
          || (data.ownerEmail is string && data.ownerEmail == request.auth.token.email)
        );
    }

    function writesPatientAuditEvent(data) {
      return signedIn()
        && data.schema == 'temperaturna-lista-audit-v1'
        && data.actorUid == request.auth.uid
        && data.accessModel == 'organization-ward-role-v1'
        && data.organizationId is string
        && data.wardId is string
        && data.clinicalPartitionKey == partitionKey(data.organizationId, data.wardId)
        && hasClinicalAccess(data.organizationId, data.wardId);
    }

    match /patients/{patientId} {
      allow create: if request.resource.data.schema == 'temperaturna-lista-patient-v1'
        && writesClinicalDocument(request.resource.data);
      allow read: if isSuperAdmin()
        || readsClinicalDocument(resource.data)
        || readsLegacyOwnedPatientForMigration(resource.data);
      allow delete: if false;
      allow update: if (isSuperAdmin() || readsClinicalDocument(resource.data) || readsLegacyOwnedPatientForMigration(resource.data))
        && request.resource.data.schema == 'temperaturna-lista-patient-v1'
        && writesClinicalDocument(request.resource.data);
    }

    match /patientAuditEvents/{eventId} {
      allow create: if writesPatientAuditEvent(request.resource.data);
      allow read: if isSuperAdmin() || readsClinicalDocument(resource.data);
      allow update, delete: if false;
    }

    match /parserTestCases/{caseId} {
      allow create: if request.resource.data.schema == 'temperaturna-lista-parser-test-case-v1'
        && writesClinicalDocument(request.resource.data);
      allow read, delete: if readsClinicalDocument(resource.data);
      allow update: if readsClinicalDocument(resource.data)
        && request.resource.data.schema == 'temperaturna-lista-parser-test-case-v1'
        && writesClinicalDocument(request.resource.data);
    }

    match /userProfiles/{userId} {
      allow read: if (signedIn() && userId == request.auth.uid) || isSuperAdmin();
      allow create, update: if (
          signedIn()
          && userId == request.auth.uid
          && validClinicalProfileData(request.resource.data, userId)
        ) || (
          isSuperAdmin()
          && validManagedUserProfileData(request.resource.data, userId)
        );
      allow delete: if false;
    }
  }
}
